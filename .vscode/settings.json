{
    "clangd.arguments": [
        "--query-driver=/usr/bin/gcc,/usr/bin/g++"
    ],
    "clangd.fallbackFlags": [
        "-std=c++17"
    ],
    "cmake.debugConfig": {
        "args": [
            // "--verbose",
            // "true",
            // "--filename",
            // "${workspaceFolder}/app/test.json"
        ],
        "externalConsole": true
    },
    // "cmake.buildDirectory": "${workspaceFolder}/build-${buildKit}",
    "files.associations": {
        "*.pyx": "cython",
        ".clang*": "yaml",
        "*.gpj": "jsonc",
        "*.gvw": "jsonc",
        "*.hpp.in": "cpp",
        "string": "cpp",
        "chrono": "cpp",
        "filesystem": "cpp"
    }
}

